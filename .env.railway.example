# ─────────────────────────────────────────────
# WhatsApp AI - Railway Production Config
# ─────────────────────────────────────────────

# Ollama (Servidor Externo)
# Debe apuntar a tu servidor Ollama con GPU (VPS, servidor dedicado, etc.)
# Ejemplo: https://ollama.tudominio.com/v1 o http://IP-PUBLICA:11434/v1
OLLAMA_BASE_URL=http://TU_SERVIDOR_OLLAMA:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llava:7b

# Meta Cloud API (WhatsApp Business)
WHATSAPP_TOKEN=${WHATSAPP_TOKEN}
WHATSAPP_PHONE_NUMBER_ID=${WHATSAPP_PHONE_NUMBER_ID}
WHATSAPP_VERIFY_TOKEN=${WHATSAPP_VERIFY_TOKEN}

# PostgreSQL (Railway proporciona DATABASE_URL automáticamente)
DATABASE_URL=${DATABASE_URL}

# Admin API Key
ADMIN_API_KEY=${ADMIN_API_KEY}

# App
DEBUG=false
ENVIRONMENT=production
PORT=8000
