# ─────────────────────────────────────────────
# WhatsApp AI - Railway Production Config
# ─────────────────────────────────────────────

# PostgreSQL (Railway lo proporciona automáticamente)
# Railway crea esta variable automáticamente, usa: ${{Postgres.DATABASE_URL}}
# IMPORTANTE: Railway provee postgresql:// pero necesitamos postgresql+asyncpg://
# El código automáticamente convierte el formato
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Ollama (Servidor Externo - REQUERIDO)
# Debe apuntar a tu servidor Ollama (VPS, ngrok, etc.)
# Ejemplos:
#   - ngrok: https://xxxx.ngrok.io/v1
#   - VPS: https://ollama.tudominio.com/v1
#   - IP: http://123.45.67.89:11434/v1
OLLAMA_BASE_URL=https://tu-ollama-url.com/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llava:7b

# Meta Cloud API (WhatsApp Business)
# Obtén estos valores en developers.facebook.com
WHATSAPP_TOKEN=EAAxxxx...
WHATSAPP_PHONE_NUMBER_ID=123456789012
WHATSAPP_VERIFY_TOKEN=tu_token_secreto_aqui

# Admin API Key (genera una clave segura)
ADMIN_API_KEY=genera_una_clave_segura_aqui

# App
ENVIRONMENT=production
DEBUG=false
PORT=8000
