# ─────────────────────────────────────────────
# WhatsApp AI Automation Engine - Environment
# ─────────────────────────────────────────────

# Ollama (LLM local)
# En Docker Compose: el servicio se llama 'ollama', puerto 11434
# En local (sin Docker): http://localhost:11434/v1
# Con túnel localtunnel: https://botjurico-ollama.loca.lt/v1
OLLAMA_BASE_URL=https://botjurico-ollama.loca.lt/v1
# Modelos disponibles: qwen2.5:7b (recomendado) | llama3.2:3b (más rápido pero menos preciso)
OLLAMA_MODEL=qwen2.5:7b
# Modelo de visión para análisis de imágenes
OLLAMA_VISION_MODEL=llava:7b

# Meta Cloud API (WhatsApp Business)
# Obtén estos valores en developers.facebook.com
WHATSAPP_TOKEN=EAAxxxx...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=legal-platform-refresh-secret-key-change-in-production-2024

# PostgreSQL
# Para Railway, construye la URL con tus credenciales:
# postgresql+asyncpg://USUARIO:PASSWORD@HOST:PUERTO/DATABASE
# Ejemplo: postgresql+asyncpg://postgres:mipassword@reseau.proxy.rlwy.net:13605/railway
# 
# Usa build_railway_url.py para construirla automáticamente
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/automation_db

# Admin API Key (protege el panel de administración)
ADMIN_API_KEY=cambia_esta_clave_antes_de_produccion

# App
DEBUG=false
ENVIRONMENT=production
